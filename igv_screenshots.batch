#
# IGV batch script for Case 2 Supplementary Figure
# (WES coverage at LRS-defined breakpoints vs captured exons)
#
# Usage on macOS (with IGV Desktop installed; brew install --cask igv):
#   igv -b igv_screenshots.batch
#
# Or open IGV Desktop GUI -> Tools -> Run Batch Script... -> select this file.
#
# Output PNGs land in OUT_DIR (set below). Set BAM and OUT_DIR before running.
#

new
genome hg38

# --- Inputs (edit these two lines) ---
load /Users/changym/Desktop/LR_WGS/Case2/WES/AA001181/AA001181.bam
snapshotDirectory /Users/changym/Desktop/LR_WGS/Case2/WES/Manta/igv

# Track presentation
maxPanelHeight 600
preference SAM.SHADE_BASE_QUALITY false
preference SAM.SHOW_CENTER_LINE true
preference SAM.MAX_VISIBLE_RANGE 100

# ---------------------------------------------------------------------------
# Panel A: TP53 exon 4 (chr17:7,675,994-7,676,272)
#   Captured positive control. Expect a tall pile-up of paired reads.
# ---------------------------------------------------------------------------
goto chr17:7675500-7676800
sort base
collapse
snapshot panel_A_TP53_exon4_captured.png

# ---------------------------------------------------------------------------
# Panel B: AUTS2 exon 2 (chr7:69,899,286-69,899,498)
#   AUTS2 captured-exon control (~275x in our run).
# ---------------------------------------------------------------------------
goto chr7:69898800-69900000
sort base
collapse
snapshot panel_B_AUTS2_exon2_captured.png

# ---------------------------------------------------------------------------
# Panel C: AUTS2 intron 2 LRS breakpoint (chr7:69,938,691)
#   ~0.07x; expect blank coverage track. Show ±5 kb context.
# ---------------------------------------------------------------------------
goto chr7:69933691-69943691
collapse
snapshot panel_C_breakpoint_AUTS2_intron2.png

# ---------------------------------------------------------------------------
# Panel D: 7q21.3 LRS breakpoint partner (chr7:95,720,897)
#   ~0.16x; expect blank coverage track. Show ±5 kb context.
# ---------------------------------------------------------------------------
goto chr7:95715897-95725897
collapse
snapshot panel_D_breakpoint_7q21.3.png

# ---------------------------------------------------------------------------
# Optional Panel E: zoom-out view across whole AUTS2 (chr7:69.6-70.8 Mb)
#   Captures the gene-wide exon-vs-intron coverage pattern in one image.
# ---------------------------------------------------------------------------
goto chr7:69598000-70794000
collapse
snapshot panel_E_AUTS2_genewide.png

exit
